# Copy this file to .env and replace placeholders locally.
# Never commit real credentials.

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Server-side/local administration only. Never expose this through VITE_*.
SUPABASE_SERVICE_ROLE_KEY=never_commit_service_role_key

# Optional future integrations. These are not required by the current frontend.
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here
